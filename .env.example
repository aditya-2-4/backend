# FarmGuard Backend Configuration Template
# Copy this file to .env in the backend folder and fill in the secrets.

# Port to listen on
PORT=5000

# JSON Web Token Secret. Change this to a secure random string!
JWT_SECRET=super_secure_random_jwt_secret_key_change_me_in_production

# Shared API Key for ESP32/Collar Devices to authenticate status, location, and event triggers.
DEVICE_API_KEY=secure_esp32_device_shared_api_key_2026

# Allowed origin for CORS requests in production (e.g. your front-end domain)
CORS_ORIGIN=http://localhost:5173

# Initial admin seeding password. Used on first DB initialize if user count is 0.
INITIAL_ADMIN_PASSWORD=admin123
